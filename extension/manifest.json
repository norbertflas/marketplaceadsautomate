{
  "manifest_version": 3,
  "name": "Allegro Ads Automate",
  "version": "1.0.0",
  "description": "Automatyzacja i optymalizacja kampanii Allegro Ads – harmonogram CPC, globalne zmiany stawek, historia zmian, raporty netto.",
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Allegro Ads Automate"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://salescenter.allegro.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/index.html",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://salescenter.allegro.com/*",
    "https://edge.salescenter.allegro.com/*",
    "https://*.allegro.com/*"
  ],
"content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
